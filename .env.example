# Copy to .env and adjust. The installer (deploy/install.sh) generates this for
# you via the TUI wizard.

# --- HTTPS ----------------------------------------------------------------
# Caddy mints its internal/self-signed certificate for these exact names/IPs.
# The installer writes localhost, 127.0.0.1, the first LAN IP, hostname, and FQDN.
HTM_HTTPS_SITE_ADDRS=https://localhost:443, https://127.0.0.1:443
# Certificate name to use when a client connects without SNI, common for raw IPs.
HTM_TLS_DEFAULT_SNI=localhost

# --- Timezone --------------------------------------------------------------
# Showtimes are entered/stored as local wall-clock times, so the scheduler must
# know your zone to auto-start showings at the right moment (containers default
# to UTC). The installer fills this from the host. TZ also sets the container
# clock/log timestamps.
HTM_TIMEZONE=America/Chicago
TZ=America/Chicago

# --- Storage ---------------------------------------------------------------
HTM_DATABASE_URL=sqlite:////data/htm.db

# Path on the HOST to your media (mounted read-only into the backend).
# Point this at your NFS/SMB mount, e.g. /mnt/media.
HTM_MEDIA_HOST_PATH=./media
# Path INSIDE the container (leave as-is).
HTM_MEDIA_ROOT=/mnt/media

# --- Playback service ------------------------------------------------------
# Phase 1: the mock container. Phase 3: the host service,
# e.g. http://host.docker.internal:9000 (add an extra_hosts entry) or the host IP.
HTM_PLAYBACK_URL=http://playback:9000
# mock keeps the full app demoable without hardware; ffmpeg runs real playback
# processes and uses the configured video/audio outputs and idle screen.
HTM_PLAYBACK_DRIVER=mock
# Optional exact ffmpeg targets discovered/configured on the host. When omitted,
# decklink:0 defaults to HTM_DECKLINK_DEVICE and HDMI/S/PDIF audio default to ALSA "default".
# HTM_VIDEO_OUTPUTS_JSON=[{"id":"decklink:0","name":"DeckLink SDI","type":"sdi","embedded_audio":true,"ffmpeg_args":["-f","decklink","DeckLink SDI"]}]
# HTM_AUDIO_OUTPUTS_JSON=[{"id":"hdmi-0","name":"AVR HDMI","type":"hdmi","ffmpeg_args":["-f","alsa","hw:0,3"]}]

# --- Theater identity ------------------------------------------------------
HTM_THEATER_NAME=Home Cinema

# --- Seat grid -------------------------------------------------------------
HTM_SEAT_MAX_ROW=F
HTM_SEAT_MAX_NUMBER=6

# --- Tickets ---------------------------------------------------------------
# Tickets are generated as PDFs and printed from the operator's workstation to
# any printer it can reach (network/USB/thermal/normal). Default style:
# receipt (80mm thermal) | fullpage (8.5x11 color)
HTM_TICKET_STYLE=receipt

# --- Hardware discovery ----------------------------------------------------
# Written by deploy/discover.sh into ./runtime (mounted at /runtime).
HTM_HARDWARE_FILE=/runtime/hardware.json
